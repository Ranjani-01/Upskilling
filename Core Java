25.HashMap Example
import java.util.*;
public class hash{
    public static void main(String[] args){
        HashMap<Integer,String> map=new HashMap<>();
        map.put(1,"Ranjani");
        map.put(2,"Ganeshan");
        map.put(3,"Kaviya");
        map.put(4,"Sumathi");
        for(int key:map.keySet()){
            System.out.println(key+" "+map.get(key));
        }
    }
}
